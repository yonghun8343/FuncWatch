{
  "name": "funcwatch",
  "version": "0.1.0",
  "description": "Call-graph-based change impact analysis for JavaScript PR review",
  "main": "src/index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:unit": "jest test/unit",
    "test:integration": "jest test/integration",
    "test:coverage": "jest --coverage",
    "graph:dot": "node tools/dot-export.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yonghun8343/FuncWatch.git"
  },
  "keywords": [
    "call-graph",
    "pagerank",
    "ccg",
    "change-impact-analysis",
    "ast",
    "static-analysis"
  ],
  "author": "yonghun",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/yonghun8343/FuncWatch/issues"
  },
  "homepage": "https://github.com/yonghun8343/FuncWatch#readme",
  "dependencies": {
    "@babel/generator": "^7.28.0",
    "@babel/parser": "^7.27.7",
    "@babel/traverse": "^7.27.7",
    "graphlib": "^2.1.8",
    "graphlib-dot": "^0.6.4"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/Test/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "verbose": true
  }
}
