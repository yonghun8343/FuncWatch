  "edges": [
    {"from": "A", "to": "B", "kind": "direct", "context": {"ifDepth": 0, "loopDepth": 0}, "contextKind": "uncond", "reachable": true, "weight": 1.0},
    {"from": "B", "to": "C", "kind": "direct", "context": {"ifDepth": 0, "loopDepth": 1}, "contextKind": "loop", "reachable": true, "weight": 10.0}
