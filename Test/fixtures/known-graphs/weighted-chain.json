{
  "name": "weighted-chain",
  "description": "3-node chain A ג†’ B ג†’ C, but with Bג†’C in LOOP context. Edge weight = ־±^ifDepth * ־²^loopDepth (default ־±=0.5, ־²=10).",
  "nodes": [
    {"id": "A", "kind": "function", "name": "A"},
    {"id": "B", "kind": "function", "name": "B"},
    {"id": "C", "kind": "function", "name": "C"}
